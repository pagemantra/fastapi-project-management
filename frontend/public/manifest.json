{
  "name": "Work Tracker",
  "short_name": "WorkTracker",
  "description": "Employee Work Tracking & Time Management System",
  "start_url": "/?source=pwa",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone"],
  "background_color": "#ffffff",
  "theme_color": "#1890ff",
  "orientation": "any",
  "scope": "/",
  "id": "/",
  "launch_handler": {
    "client_mode": ["navigate-existing", "auto"]
  },
  "handle_links": "preferred",
  "icons": [
    {
      "src": "/icons/icon-192x192.svg",
      "sizes": "192x192",
      "type": "image/svg+xml",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-192x192.svg",
      "sizes": "512x512",
      "type": "image/svg+xml",
      "purpose": "any"
    },
    {
      "src": "/vite.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "maskable"
    }
  ],
  "shortcuts": [
    {
      "name": "Clock In",
      "short_name": "Clock In",
      "description": "Start your work session",
      "url": "/dashboard?action=clockin",
      "icons": [{ "src": "/icons/icon-192x192.svg", "sizes": "192x192" }]
    },
    {
      "name": "My Worksheets",
      "short_name": "Worksheets",
      "description": "View your worksheets",
      "url": "/worksheets",
      "icons": [{ "src": "/icons/icon-192x192.svg", "sizes": "192x192" }]
    }
  ],
  "categories": ["business", "productivity"],
  "prefer_related_applications": false,
  "edge_side_panel": {
    "preferred_width": 400
  }
}
